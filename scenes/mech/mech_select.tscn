[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/mech/mech_select.gd" id="1_mech_select"]

[node name="MechSelect" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_mech_select")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.047, 0.058, 0.066, 1)

[node name="MainVBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 0

[node name="Header" type="HBoxContainer" parent="MainVBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_constants/separation = 8

[node name="BackButton" type="Button" parent="MainVBox/Header"]
layout_mode = 2
text = "<- Menu"

[node name="TitleLabel" type="Label" parent="MainVBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "MECH BAY"
horizontal_alignment = 1
vertical_alignment = 1

[node name="CurrentMechLabel" type="Label" parent="MainVBox/Header"]
layout_mode = 2
text = "Current: none"
horizontal_alignment = 2
vertical_alignment = 1

[node name="ContentHBox" type="HBoxContainer" parent="MainVBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 0

[node name="ListPanel" type="PanelContainer" parent="MainVBox/ContentHBox"]
layout_mode = 2
custom_minimum_size = Vector2(240, 0)

[node name="ListVBox" type="VBoxContainer" parent="MainVBox/ContentHBox/ListPanel"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="FilterRow" type="HBoxContainer" parent="MainVBox/ContentHBox/ListPanel/ListVBox"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="AllBtn" type="Button" parent="MainVBox/ContentHBox/ListPanel/ListVBox/FilterRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "All"

[node name="LightBtn" type="Button" parent="MainVBox/ContentHBox/ListPanel/ListVBox/FilterRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Lt"

[node name="MedBtn" type="Button" parent="MainVBox/ContentHBox/ListPanel/ListVBox/FilterRow"]
