text = "Hvy"

[node name="AstBtn" type="Button" parent="MainVBox/ContentHBox/ListPanel/ListVBox/FilterRow"]
layout_mode = 2
size_flags_horizontal = 3
text = "Ast"

[node name="MechList" type="ItemList" parent="MainVBox/ContentHBox/ListPanel/ListVBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="DetailPanel" type="PanelContainer" parent="MainVBox/ContentHBox"]
layout_mode = 2
