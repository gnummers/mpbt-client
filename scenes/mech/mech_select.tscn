[connection signal="pressed" from="MainVBox/Header/BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="MainVBox/ContentHBox/ListPanel/ListVBox/FilterRow/AllBtn" to="." method="_on_filter_all"]
