[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/character/character.gd" id="1_char_script"]

[node name="Character" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_char_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.047, 0.058, 0.066, 1)

[node name="Content" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -220.0
offset_top = -180.0
offset_right = 220.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Content"]
layout_mode = 2
text = "Choose Your MechWarrior"
horizontal_alignment = 1

[node name="StatusLabel" type="Label" parent="Content"]
layout_mode = 2
text = ""
horizontal_alignment = 1
autowrap_mode = 3

[node name="Form" type="VBoxContainer" parent="Content"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="NameLabel" type="Label" parent="Content/Form"]
layout_mode = 2
text = "Call Sign"

[node name="NameInput" type="LineEdit" parent="Content/Form"]
layout_mode = 2
placeholder_text = "Enter your MechWarrior name"

[node name="AllegianceLabel" type="Label" parent="Content/Form"]
layout_mode = 2
text = "House Allegiance"

[node name="AllegianceOption" type="OptionButton" parent="Content/Form"]
layout_mode = 2

[node name="SubmitButton" type="Button" parent="Content/Form"]
layout_mode = 2
text = "Enlist"

[node name="BackButton" type="Button" parent="Content"]
layout_mode = 2
text = "\u2190 Back"
flat = true

[connection signal="pressed" from="Content/Form/SubmitButton" to="." method="_on_submit_pressed"]
[connection signal="pressed" from="Content/BackButton" to="." method="_on_back_pressed"]
