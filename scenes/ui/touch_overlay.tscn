; MPBT touch overlay scene — M10 mobile/tablet controls.
; CanvasLayer layer=10 (above HUD CanvasLayer).
; Layout (at 1280x720 design res, canvas_items stretch/expand):
;   JoystickAnchor — bottom-left corner 20px margin, 160x160 area
;   LookZone       — right half of screen (anchor_left=0.5)
;   FireButton     — bottom-right corner

[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scenes/ui/touch_overlay.gd" id="1_overlay"]
[ext_resource type="Script" path="res://scripts/ui/virtual_joystick.gd" id="2_joystick"]
[ext_resource type="Script" path="res://scripts/ui/touch_look_zone.gd" id="3_lookzone"]

[node name="TouchOverlay" type="CanvasLayer"]
layer = 10
script = ExtResource("1_overlay")

[node name="JoystickAnchor" type="Control" parent="."]
layout_mode = 1
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = -180.0
offset_right = 180.0
offset_bottom = -20.0
grow_horizontal = 1
grow_vertical = 0

[node name="MoveJoystick" type="Control" parent="JoystickAnchor"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("2_joystick")

[node name="LookZone" type="Control" parent="."]
layout_mode = 1
anchor_left = 0.5
anchor_top = 0.0
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 1
grow_vertical = 2
script = ExtResource("3_lookzone")

[node name="FireButton" type="Button" parent="."]
layout_mode = 1
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -120.0
offset_top = -100.0
offset_right = -20.0
offset_bottom = -20.0
grow_horizontal = 0
grow_vertical = 0
custom_minimum_size = Vector2(100.0, 80.0)
text = "FIRE"
theme_override_font_sizes/font_size = 16
