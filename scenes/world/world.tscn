[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scenes/world/world.gd" id="1_world_script"]
[ext_resource type="Script" path="res://scripts/world/solaris_map.gd" id="2_map_script"]

[node name="World" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_world_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.047, 0.058, 0.066, 1)

[node name="MainVBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 0

[node name="Header" type="HBoxContainer" parent="MainVBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 40)
theme_override_constants/separation = 8

[node name="TitleLabel" type="Label" parent="MainVBox/Header"]
layout_mode = 2
text = "SOLARIS VII"
vertical_alignment = 1

[node name="StatusLabel" type="Label" parent="MainVBox/Header"]
layout_mode = 2
size_flags_horizontal = 3
text = ""
horizontal_alignment = 1
vertical_alignment = 1

[node name="UserLabel" type="Label" parent="MainVBox/Header"]
layout_mode = 2
text = ""
horizontal_alignment = 2
vertical_alignment = 1

[node name="CbillsLabel" type="Label" parent="MainVBox/Header"]
layout_mode = 2
text = ""
horizontal_alignment = 2
vertical_alignment = 1
theme_override_font_sizes/font_size = 13

[node name="ComStarButton" type="Button" parent="MainVBox/Header"]
layout_mode = 2
text = "ComStar"

[node name="ComStarBadge" type="Label" parent="MainVBox/Header"]
layout_mode = 2
text = ""
visible = false

[node name="BackButton" type="Button" parent="MainVBox/Header"]
layout_mode = 2
text = "\u2190 Menu"

[node name="ContentHBox" type="HBoxContainer" parent="MainVBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 0

[node name="RoomPanel" type="PanelContainer" parent="MainVBox/ContentHBox"]
layout_mode = 2
custom_minimum_size = Vector2(240, 0)

[node name="RoomVBox" type="VBoxContainer" parent="MainVBox/ContentHBox/RoomPanel"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="RoomPanelTitle" type="Label" parent="MainVBox/ContentHBox/RoomPanel/RoomVBox"]
layout_mode = 2
text = "Rooms"
horizontal_alignment = 1

[node name="RoomScroll" type="ScrollContainer" parent="MainVBox/ContentHBox/RoomPanel/RoomVBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="RoomList" type="VBoxContainer" parent="MainVBox/ContentHBox/RoomPanel/RoomVBox/RoomScroll"]
layout_mode = 2
size_flags_horizontal = 3

[node name="DetailPanel" type="VBoxContainer" parent="MainVBox/ContentHBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="RoomName" type="Label" parent="MainVBox/ContentHBox/DetailPanel"]
layout_mode = 2
text = "Select a room"
horizontal_alignment = 1

[node name="RoomDesc" type="Label" parent="MainVBox/ContentHBox/DetailPanel"]
layout_mode = 2
text = ""
autowrap_mode = 3
horizontal_alignment = 1

[node name="PresencePanel" type="VBoxContainer" parent="MainVBox/ContentHBox/DetailPanel"]
layout_mode = 2
visible = false
theme_override_constants/separation = 4

[node name="PresenceHeader" type="Label" parent="MainVBox/ContentHBox/DetailPanel/PresencePanel"]
layout_mode = 2
text = "In this room:"

[node name="PresenceList" type="VBoxContainer" parent="MainVBox/ContentHBox/DetailPanel/PresencePanel"]
layout_mode = 2
theme_override_constants/separation = 2

[node name="ChatPanel" type="VBoxContainer" parent="MainVBox/ContentHBox/DetailPanel"]
layout_mode = 2
visible = false
theme_override_constants/separation = 4

[node name="ChatHeader" type="Label" parent="MainVBox/ContentHBox/DetailPanel/ChatPanel"]
layout_mode = 2
text = "Room chat:"

[node name="ChatScroll" type="ScrollContainer" parent="MainVBox/ContentHBox/DetailPanel/ChatPanel"]
layout_mode = 2
size_flags_vertical = 3
custom_minimum_size = Vector2(0, 100)

[node name="ChatLog" type="VBoxContainer" parent="MainVBox/ContentHBox/DetailPanel/ChatPanel/ChatScroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="ChatHBox" type="HBoxContainer" parent="MainVBox/ContentHBox/DetailPanel/ChatPanel"]
layout_mode = 2
theme_override_constants/separation = 4

[node name="ChatInput" type="LineEdit" parent="MainVBox/ContentHBox/DetailPanel/ChatPanel/ChatHBox"]
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Say something\u2026"
max_length = 200

[node name="SendButton" type="Button" parent="MainVBox/ContentHBox/DetailPanel/ChatPanel/ChatHBox"]
layout_mode = 2
text = "Send"
disabled = true

[node name="MapCanvas" type="Control" parent="MainVBox/ContentHBox/DetailPanel"]
layout_mode = 2
size_flags_vertical = 3
custom_minimum_size = Vector2(0, 200)
script = ExtResource("2_map_script")

[node name="ActionBar" type="HBoxContainer" parent="MainVBox/ContentHBox/DetailPanel"]
layout_mode = 2

[node name="HSpacer" type="Control" parent="MainVBox/ContentHBox/DetailPanel/ActionBar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="EnterButton" type="Button" parent="MainVBox/ContentHBox/DetailPanel/ActionBar"]
layout_mode = 2
text = "Enter Room"
disabled = true

[node name="PollTimer" type="Timer" parent="."]
wait_time = 5.0
autostart = false

[connection signal="pressed" from="MainVBox/Header/BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="MainVBox/ContentHBox/DetailPanel/ActionBar/EnterButton" to="." method="_on_enter_pressed"]
[connection signal="pressed" from="MainVBox/ContentHBox/DetailPanel/ChatPanel/ChatHBox/SendButton" to="." method="_on_send_pressed"]
[connection signal="text_submitted" from="MainVBox/ContentHBox/DetailPanel/ChatPanel/ChatHBox/ChatInput" to="." method="_on_chat_submitted"]
[connection signal="timeout" from="PollTimer" to="." method="_on_poll_timer_timeout"]
