[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/login/login.gd" id="1_login_script"]

[node name="Login" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_login_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.047, 0.058, 0.066, 1)

[node name="Content" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -160.0
offset_right = 200.0
offset_bottom = 160.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Content"]
layout_mode = 2
text = "MPBT: Solaris VII"
horizontal_alignment = 1

[node name="Form" type="VBoxContainer" parent="Content"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="UsernameInput" type="LineEdit" parent="Content/Form"]
layout_mode = 2
placeholder_text = "Username"

[node name="EmailRow" type="VBoxContainer" parent="Content/Form"]
layout_mode = 2
visible = false

[node name="EmailInput" type="LineEdit" parent="Content/Form/EmailRow"]
layout_mode = 2
placeholder_text = "Email address"

[node name="PasswordInput" type="LineEdit" parent="Content/Form"]
layout_mode = 2
placeholder_text = "Password"
secret = true

[node name="SubmitButton" type="Button" parent="Content/Form"]
layout_mode = 2
text = "Sign In"

[node name="StatusLabel" type="Label" parent="Content"]
layout_mode = 2
text = ""
horizontal_alignment = 1
autowrap_mode = 3

[node name="ToggleButton" type="Button" parent="Content"]
layout_mode = 2
text = "No account? Register"
flat = true

[connection signal="pressed" from="Content/Form/SubmitButton" to="." method="_on_submit_pressed"]
[connection signal="pressed" from="Content/ToggleButton" to="." method="_on_toggle_pressed"]
